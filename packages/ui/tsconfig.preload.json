{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "declaration": false,
    "esModuleInterop": true
  },
  "include": ["electron/preload.ts"],
  "exclude": ["node_modules"]
}
