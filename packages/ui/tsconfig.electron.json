{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "declaration": false,
    "esModuleInterop": true
  },
  "include": ["electron/main.ts", "electron/shell-env.ts"],
  "exclude": ["node_modules", "electron/preload.ts"]
}
