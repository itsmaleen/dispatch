  },
  "keywords": ["openclaw", "channel", "agent-command-center"],
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
