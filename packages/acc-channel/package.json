{
  "name": "@acc/channel-plugin",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for Agent Command Center",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "acc",
      "label": "Agent Command Center",
      "selectionLabel": "ACC (WebSocket)",
      "docsPath": "/channels/acc",
      "docsLabel": "acc-channel",
      "blurb": "Connect OpenClaw to Agent Command Center via WebSocket.",
      "order": 100,
      "aliases": [
        "acc",
        "command-center"
      ]
    },
    "install": {
      "npmSpec": "@acc/channel-plugin",
      "localPath": "packages/acc-channel",
      "defaultChoice": "local"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "openclaw": ">=2.6.0"
  }
}
