{
  "name": "@acc/channel",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for Agent Command Center",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
